# ── Option 1: Azure OpenAI (recommended for your stack) ──────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o            # your chat deployment name
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002   # your embedding deployment

# ── Option 2: Standard OpenAI (fallback) ─────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
