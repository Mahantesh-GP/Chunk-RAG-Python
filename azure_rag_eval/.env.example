# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o                        # chat model
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002  # embedding model

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX=rag-chunks-index                   # your index name

# ── Evaluation Settings ───────────────────────────────────────────────────────
TOP_K=5                  # how many chunks to retrieve per question
ATTRIBUTION_THRESHOLD=2  # reranker score threshold (0-4) to mark chunk as attributed
